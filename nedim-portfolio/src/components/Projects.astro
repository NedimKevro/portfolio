---
const featured = {
  title: "GIBUD Auction House Platform",
  role: "Full Stack Developer · P23",
  description: "A production-scale online auction marketplace supporting live bidding, real-time messaging, favorites, carts, and full listing management — built to handle real transactional load, not a demo.",
  problem: "Auction platforms need to feel instant. Bids, chat, and cart state all had to stay in sync across every connected client without flooding the database or losing events under load.",
  approach: "I designed the backend around a repository/service pattern with a transactional outbox, background workers, retries, and dead-letter queue handling — so every state change is reliable even if a downstream service is briefly unavailable. Ably handles the real-time layer for bidding, chat, and live updates.",
  stack: ["Next.js App Router", "React 19", "TypeScript", "PostgreSQL", "Prisma", "Auth0", "Ably", "AWS S3", "Amazon SES", "Sentry"],
};

const projects = [
  { title: "Booking Platform", description: "Real-time availability booking system with Firebase backend and a smooth Next.js frontend.", stack: ["Next.js", "Firebase", "Tailwind CSS"] },
  { title: "Home Services Marketplace", description: "Two-sided marketplace connecting homeowners with service providers, built with Remix for fast SSR.", stack: ["Remix", "Firebase", "Node.js"] },
  { title: "Kanban Project Manager", description: "Drag-and-drop project management with real-time sync via Hasura GraphQL.", stack: ["Next.js", "Zustand", "Hasura"] },
];
---
<section id="projects" style="padding:6rem 0;">
  <div class="container reveal">
    <p class="section-label" style="margin-bottom:2.5rem;">
      <span class="num">02.</span> Featured Project <span class="line"></span>
    </p>

    <div class="card" style="margin-bottom:3rem;">
      <p class="mono" style="color:#64FFDA;font-size:0.8rem;margin-bottom:0.5rem;">{featured.role}</p>
      <h3 class="display" style="font-size:1.4rem;margin-bottom:1rem;">{featured.title}</h3>
      <p style="color:#8B95A7;line-height:1.85;margin-bottom:1.25rem;font-size:0.925rem;">{featured.description}</p>

      <div style="margin-bottom:1.25rem;">
        <p class="mono" style="color:#E4E6EB;font-size:0.8rem;font-weight:500;margin-bottom:0.4rem;">The problem</p>
        <p style="color:#8B95A7;line-height:1.8;font-size:0.875rem;">{featured.problem}</p>
      </div>
      <div style="margin-bottom:1.5rem;">
        <p class="mono" style="color:#E4E6EB;font-size:0.8rem;font-weight:500;margin-bottom:0.4rem;">My approach</p>
        <p style="color:#8B95A7;line-height:1.8;font-size:0.875rem;">{featured.approach}</p>
      </div>

      <div style="display:flex;flex-wrap:wrap;gap:0.5rem;">
        {featured.stack.map(t => <span class="tag">{t}</span>)}
      </div>
    </div>

    <p class="section-label" style="margin-bottom:1.5rem;">
      Other Noteworthy Projects <span class="line"></span>
    </p>

    <div style="display:flex;flex-direction:column;gap:1rem;">
      {projects.map(p => (
        <div class="card">
          <h4 style="font-weight:700;font-size:1rem;margin-bottom:0.5rem;color:#E4E6EB;">{p.title}</h4>
          <p style="font-size:0.875rem;color:#8B95A7;line-height:1.7;margin-bottom:1rem;">{p.description}</p>
          <div style="display:flex;flex-wrap:wrap;gap:0.4rem;">
            {p.stack.map(t => <span class="tag">{t}</span>)}
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
