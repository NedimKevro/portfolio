---
---
<header id="nav" style="position:fixed;top:0;left:0;right:0;z-index:50;transition:all 0.3s;">
  <div class="container" style="height:64px;display:flex;align-items:center;justify-content:space-between;">
    <a href="#hero" class="mono" style="font-weight:600;font-size:1rem;color:#E4E6EB;text-decoration:none;">
      <span style="color:#64FFDA;">~/</span>nedim
    </a>
    <nav class="desktop-nav" style="display:flex;align-items:center;gap:2rem;">
      <a href="#about" class="mono navlink">01. About</a>
      <a href="#projects" class="mono navlink">02. Projects</a>
      <a href="#skills" class="mono navlink">03. Skills</a>
      <a href="#experience" class="mono navlink">04. Experience</a>
      <a href="#contact" class="btn-primary" style="padding:0.5rem 1.1rem;font-size:0.8rem;">Contact</a>
    </nav>
    <button id="mob-btn" style="display:none;background:none;border:none;color:#E4E6EB;cursor:pointer;" aria-label="Menu">
      <svg width="22" height="22" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M4 6h16M4 12h16M4 18h16"/></svg>
    </button>
  </div>
  <div id="mob-menu" style="display:none;background:#0F131C;border-top:1px solid #1D2433;padding:1rem 1.75rem 1.5rem;">
    <a href="#about" class="mono" style="display:block;color:#8B95A7;padding:0.65rem 0;text-decoration:none;font-size:0.85rem;border-bottom:1px solid #1D2433;">01. About</a>
    <a href="#projects" class="mono" style="display:block;color:#8B95A7;padding:0.65rem 0;text-decoration:none;font-size:0.85rem;border-bottom:1px solid #1D2433;">02. Projects</a>
    <a href="#skills" class="mono" style="display:block;color:#8B95A7;padding:0.65rem 0;text-decoration:none;font-size:0.85rem;border-bottom:1px solid #1D2433;">03. Skills</a>
    <a href="#experience" class="mono" style="display:block;color:#8B95A7;padding:0.65rem 0;text-decoration:none;font-size:0.85rem;border-bottom:1px solid #1D2433;">04. Experience</a>
    <a href="#contact" class="mono" style="display:block;color:#64FFDA;padding:0.65rem 0;text-decoration:none;font-size:0.85rem;font-weight:600;">Contact →</a>
  </div>
</header>

<style>
  .navlink { color: #8B95A7; text-decoration: none; font-size: 0.8rem; font-weight: 500; transition: color 0.2s; }
  .navlink:hover { color: #64FFDA; }
  @media (max-width: 720px) { .desktop-nav { display: none !important; } #mob-btn { display: block !important; } }
</style>

<script>
  const nav = document.getElementById('nav')!;
  window.addEventListener('scroll', () => {
    if (window.scrollY > 40) {
      nav.style.background = 'rgba(11,13,18,0.92)';
      nav.style.backdropFilter = 'blur(12px)';
      nav.style.borderBottom = '1px solid #1D2433';
    } else {
      nav.style.background = 'transparent';
      nav.style.backdropFilter = 'none';
      nav.style.borderBottom = 'none';
    }
  });
  const btn = document.getElementById('mob-btn')!;
  const menu = document.getElementById('mob-menu')!;
  btn.addEventListener('click', () => menu.style.display = menu.style.display === 'none' ? 'block' : 'none');
  menu.querySelectorAll('a').forEach(a => a.addEventListener('click', () => menu.style.display = 'none'));
</script>
